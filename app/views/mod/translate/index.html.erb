<% title(t('mod.translation_dashboard')) %>

<div class="card mb-3">
  <h5 class="card-header d-flex justify-content-between align-items-center">
    <%= link_to t('mod.manage_translations'), mod_translate_path, class: 'unstyled' %>
    <%= search_form_for(@q, url: mod_translate_path, enforce_utf8: false,
                        class: 'form form-inline search-form d-flex') do |f| %>
      <%= f.collection_select :sources_type_id_eq, @source_types, :id, :name,
        { include_blank: t('all.sources') }, class: 'form-control form-control-sm' %>
      <%= f.submit t('search'), name: nil, class: 'btn btn-secondary btn-sm mr-0' %>
    <% end %>
  </h5>
  <div class="card-body card-table">
    <table class="table table-striped table-sm">
      <tr>
        <th></th> <!-- Image -->
        <th></th> <!-- Icon -->
        <th><%= t('name') %></th>
        <th><%= t('source') %></th>
        <th class="text-center"><%= t('patch') %></th>
        <th></th> <!-- Actions -->
      </tr>
      <% @collectables.each do |collectable| %>
        <tr>
          <td><%= collectable_image_link(collectable) %></td>
          <td><%= collectable_icon(collectable) %></td>
          <td class="name">
            <%= collectable.name %>
            <%= gender_symbol(collectable.try(:gender)) %>
          </td>
          <td>
            <% if collectable.class == SurveyRecord %>
              <%= collectable.solution %>
            <% else %>
              <%= sources(collectable) %>
            <% end %>
          </td>
          <td class="text-center"><%= collectable.patch %></td>
          <td class="text-center">
            <%= link_to fa_icon('pen'), polymorphic_url([:mod, collectable], action: :edit),
              class: 'btn btn-secondary btn-sm' %>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
  <div class="card-footer d-flex justify-content-center mb-0">
    <%= will_paginate(@collectables) %>
  </div>
</div>

<% title(t('mod.dashboard')) %>

<div class="card shadow mb-3">
  <h5 class="card-header d-flex justify-content-between align-items-center">
    <%= link_to t('mod.manage_collectables'), mod_dashboard_path, class: 'unstyled' %>
    <%= link_to t('mod.translation_dashboard'), mod_translate_path, class: 'btn btn-primary' %>
  </h5>
  <div class="card-body">
    <div class="d-flex flex-wrap justify-content-center">
      <% [Mount, Minion, Hairstyle, Emote, Orchestrion, Frame, Spell, Barding, Fashion, Facewear, Outfit, Armoire, Card, Record, SurveyRecord, OccultRecord].each do |model| %>
        <%= link_to polymorphic_url([:mod, model]), class: 'btn btn-secondary mx-1 my-2' do %>
          <%= collectable_icon(model.to_s) %>
          <%= t("#{model.to_s.tableize}.title") %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
<div class="card shadow">
  <h5 class="card-header"><%= t('mod.changelog') %></h5>
  <div class="card-body card-table">
    <%= render 'change_table', changes: @changes %>
  </div>
  <div class="card-footer d-flex justify-content-center mb-0">
    <%= will_paginate(@changes) %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="d-flex align-items-center">
      <%= link_to :admin_characters, class: 'unstyled mr-auto pt-1' do %>
        <h5>Manage Characters</h5>
      <% end %>
      <%= search_form_for(@q, url: admin_characters_path, class: 'form form-inline admin-search-form') do |f| %>
        <%= check_box_tag :verified, 1, @verified, class: 'form-control' %>
        <%= label_tag :verified %>
        <%= check_box_tag :public, 1, @public, class: 'form-control' %>
        <%= label_tag :public %>
        <%= check_box_tag :supporter, 1, @supporter, class: 'form-control' %>
        <%= label_tag :supporter %>
        <%= f.select :server_eq, Character.servers, { include_blank: 'All Servers' }, class: 'form-control form-control-sm' %>
        <%= f.search_field :name_cont, placeholder: 'Name', class: 'form-control form-control-sm' %>
        <%= f.search_field :id_eq, placeholder: 'ID', class: 'form-control form-control-sm' %>
        <%= f.search_field :verified_user_identities_uid_cont, placeholder: 'User UID',
          class: 'form-control form-control-sm' %>
        <%= f.submit 'Search', class: 'btn btn-secondary btn-sm' %>
      <% end %>
    </div>
  </div>
  <div class="card-body card-table">
    <table class="table table-striped table-sm">
      <tr>
        <th></th> <!-- Avatar -->
        <th>Name</th>
        <th>Server</th>
        <th>ID</th>
        <th>Last Parsed</th>
        <th>Verified User</th>
        <th class="text-center">Public</th>
        <th class="text-center">Supporter</th>
        <th class="ml-4"></th> <!-- Buttons -->
      </tr>
      <% @characters.each do |character| %>
        <tr>
          <td><%= avatar(character) %></td>
          <td><%= character.name %></td>
          <td><%= character.server %></td>
          <td><%= character.id %></td>
          <td><%= format_date(character.last_parsed) %></td>
          <td>
            <%= link_to(character.verified_user_id, admin_users_path(q: { id_eq: character.verified_user_id })) if character.verified? %>
          </td>
          <td class="text-center"><%= fa_check(character.public?, false) %></td>
          <td class="text-center"><%= fa_check(character.supporter?, false) %></td>
          <td class="pr-0">
            <%= link_to fa_icon('user'), character_path(character), class: 'btn btn-secondary btn-sm' %>
            <%= link_to fab_icon('patreon'), support_admin_character_path(character), method: :post, class: 'btn btn-secondary btn-sm' %>
            <% if character.verified? %>
              <%= link_to fa_icon('times'), unverify_admin_character_path(character), method: :delete,
                data: { confirm: 'Are you sure you want to unverify this character?' }, class: 'btn btn-secondary btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
  <div class="card-footer d-flex justify-content-center mb-0">
    <%= will_paginate(@characters) %>
  </div>
</div>

<div class="card">
  <div class="card-header d-flex align-items-center">
    <h5 class="card-title"><%= minion.name %></h5>
  </div>
  <div class="card-body">
    <div class="d-flex">
      <div class="d-none d-sm-block mr-4">
        <%= large_image(@minion) %>
      </div>
      <div class="d-flex flex-column flex-info">
        <div class="d-flex flex-wrap mb-0">
          <div>
            <dt><%= t('minions.behavior') %></dt>
            <dd><%= minion.behavior.name %></dd>
          </div>
          <div>
            <dt><%= t('tradeable') %></dt>
            <dd><%= tradeable(@minion) %></dd>
          </div>
          <%= render 'shared/ownership', collectable: @minion %>
          <div>
            <dt><%= t('patch') %></dt>
            <dd><%= minion.patch %></dd>
          </div>
        </div>
        <dt><%= t('source') %></dt>
        <dd><%= sources(minion, list: true) %></dd>
        <%= render('shared/item', collectable: @minion) %>
        <dt><%= t('description') %></dt>
        <dd><%= format_text(minion.description) %></dd>
        <dt><%= t('journal') %></dt>
        <dd><%= format_text(minion.enhanced_description) %></dd>
        <dt><%= t('tooltip') %></dt>
        <dd><%= format_text(minion.tooltip) %></dd>
        <div class="d-block d-sm-none">
          <%= large_image(@minion) %>
        </div>
      </div>
    </div>
    <div class="footprint">
      <%= image_tag(@minion.footprint_image_url) %>
    </div>
  </div>
</div>

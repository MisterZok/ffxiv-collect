<% title(@armoire.name) %>
<% image(@armoire.image_url) %>

<div class="row">
  <div class="col-12 col-lg-8 col-xl-6 offset-lg-2 offset-xl-3">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
          <%= small_image(@armoire) %>
          <h5 class="card-title mx-2">
            <%= @armoire.name %>
            <%= gender_symbol(@armoire.gender) %>
            <%= outfitable(@armoire) %>
          </h5>
        </div>
      </div>
      <div class="card-body py-3">
        <div class="d-flex flex-column flex-info">
          <div class="d-flex flex-wrap">
            <div>
              <dt><%= t('tradeable') %></dt>
              <dd><%= tradeable(@armoire) %></dd>
            </div>
            <%= render 'shared/ownership', collectable: @armoire %>
            <div>
              <dt><%= t('patch') %></dt>
              <dd><%= @armoire.patch %></dd>
            </div>
          </div>
          <% if @armoire.description.present? %>
            <dt><%= t('description') %></dt>
            <dd class="mb-0"><%= @armoire.description %></dd>
          <% end %>
          <dt><%= t('source') %></dt>
          <dd class="mb-0"><%= sources(@armoire, list: true) %></dd>
        </div>
      </div>
    </div>
  </div>
</div>
